          "temperature": true,
          "modalities": {
            "input": ["text", "image", "audio", "video", "pdf"],
            "output": ["text"],
          },
          "options": {
            "temperature": 0.6,
            "top_p": 0.95,
            "top_k": 20,
            "min_p": 0.0,
